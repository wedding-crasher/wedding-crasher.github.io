---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BlogArchive from "../../../components/BlogArchive.astro";
import { getCategories, getPublishedPosts, slugifyCategory } from "../../../utils/blog";

export async function getStaticPaths() {
  const posts = getPublishedPosts(await getCollection("blog"));
  const categories = getCategories(posts);

  return categories.map((category) => ({
    params: { slug: category.slug },
    props: {
      category,
      categories,
      posts: posts.filter((post) => slugifyCategory(post.data.category) === category.slug)
    }
  }));
}

const { category, categories, posts } = Astro.props;
---

<BaseLayout
  title={`${category.label} | Hangwoo Cho`}
  description={`A category archive for ${category.label} posts.`}
>
  <BlogArchive
    posts={posts}
    categories={categories}
    eyebrow="Category"
    pageTitle={`${category.label} archive`}
    pageDescription={`Posts grouped under ${category.label}, focused on the problems, trade-offs, and lessons from that track.`}
    currentCategorySlug={category.slug}
  />
</BaseLayout>