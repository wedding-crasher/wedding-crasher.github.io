---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 | Hangwoo Cho" description="The page you are looking for could not be found.">
  <main class="page-frame simple-page">
    <section class="article-card missing-card">
      <p class="sidebar-label">404</p>
      <h1>This page could not be found</h1>
      <p>The URL may have changed, or the post may not be published yet.</p>
      <a class="text-link" href="/">Return to home</a>
    </section>
  </main>
</BaseLayout>