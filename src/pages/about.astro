---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SidebarProfile from "../components/SidebarProfile.astro";
import { getCategories, getPublishedPosts } from "../utils/blog";

const posts = getPublishedPosts(await getCollection("blog"));
const categories = getCategories(posts);
---

<BaseLayout title="About | Hangwoo Cho" description="A profile page describing the purpose of the blog and the themes behind the writing.">
  <main class="page-frame article-grid">
    <section class="article-card about-card">
      <p class="sidebar-label">Profile</p>
      <h1>I am building a blog that keeps the engineering context intact</h1>
      <p>
        The center of this site is the blog. I use it to document incidents, bottlenecks, design
        changes, release strategy, and team-level decision making from real ML and LLM systems,
        while letting that body of work speak for the profile around it.
      </p>

      <div class="about-grid">
        <section>
          <h2>What this blog covers</h2>
          <ul>
            <li>Model quality, experimentation, and delivery from a Machine Learning Engineer perspective</li>
            <li>Prompting, evaluation, RAG, and cost trade-offs from an LLM Engineer perspective</li>
            <li>Deployment, monitoring, reproducibility, and operating workflows from an MLOps perspective</li>
          </ul>
        </section>

        <section>
          <h2>How I want the writing to read</h2>
          <ul>
            <li>The shape of the problem should appear before the polished result</li>
            <li>The decision criteria should outlast the one-off tip</li>
            <li>The archive should feel like an engineering log, not a static portfolio</li>
          </ul>
        </section>
      </div>

      <section class="timeline-card">
        <h2>Quick bio slots</h2>
        <p>This section is intentionally lightweight so it can be swapped out with a real bio later.</p>
        <ul>
          <li>Current role: company, team, and the product or platform you work on</li>
          <li>Interests: LLM systems, search, evaluation, MLOps</li>
          <li>Contact: GitHub, LinkedIn, email</li>
        </ul>
      </section>
    </section>

    <SidebarProfile categories={categories} />
  </main>
</BaseLayout>