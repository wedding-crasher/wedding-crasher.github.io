---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About | Hangwoo Cho" description="A short profile for Hangwoo Cho and his work on enterprise AI / ML systems.">
  <main class="simple-page">
    <section class="page-frame article-card about-simple">
      <div class="about-simple__hero">
        <img class="about-simple__photo" src="/images/profile.jpg" alt="Portrait of Hangwoo Cho" />

        <div class="about-simple__body">
          <p class="sidebar-label">About</p>
          <h1>Hangwoo Cho</h1>
          <p class="about-simple__bio">
            Solution Engineer in Microsoft's AI Build Team, working in a forward-deployed model
            to solve enterprise AI / ML challenges with customers.
          </p>

          <dl class="about-simple__meta">
            <div>
              <dt>GitHub</dt>
              <dd>
                <a href="https://github.com/wedding-crasher" target="_blank" rel="noreferrer">@wedding-crasher</a>
              </dd>
            </div>
            <div>
              <dt>LinkedIn</dt>
              <dd>
                <a href="https://www.linkedin.com/in/hangwoo-cho-01257a252" target="_blank" rel="noreferrer">hangwoo-cho-01257a252</a>
              </dd>
            </div>
          </dl>
        </div>
      </div>

      <section class="about-simple__section">
        <h2>Experience</h2>
        <ul class="about-simple__list">
          <li><strong>Software Solution Engineer</strong>, AI Build Team, Microsoft</li>
          <li><strong>ML Research Intern</strong>, Seoul National University Data Mining Laboratory</li>
          <li><strong>AI &amp; Analytics Team</strong>, PwC</li>
          <li><strong>Founder</strong>, BridgeOn</li>
        </ul>
      </section>

      <section class="about-simple__section">
        <h2>Education</h2>
        <ul class="about-simple__list">
          <li>B.E. in Convergence Software, Sungkyunkwan University</li>
          <li>B.B.A. in Global Business, Sungkyunkwan University</li>
        </ul>
      </section>
    </section>
  </main>
</BaseLayout>