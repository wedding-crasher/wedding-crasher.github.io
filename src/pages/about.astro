---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SidebarProfile from "../components/SidebarProfile.astro";
import { getCategories, getPublishedPosts } from "../utils/blog";

const posts = getPublishedPosts(await getCollection("blog"));
const categories = getCategories(posts);
---

<BaseLayout title="About | Hangwoo Cho" description="A profile page describing my role on Microsoft's AI Build Team in Korea and the enterprise AI themes behind this blog.">
  <main class="page-frame article-grid">
    <section class="article-card about-card">
      <p class="sidebar-label">Profile</p>
      <h1>I work on enterprise AI and ML problems as a Solution Engineer</h1>
      <p>
        I am a Solution Engineer on Microsoft's AI Build Team in Korea. My work centers on helping
        organizations solve enterprise business problems with AI and ML, and this blog is where I
        document the technical decisions, delivery trade-offs, and operating realities behind that work.
      </p>

      <div class="about-grid">
        <section>
          <h2>What this blog covers</h2>
          <ul>
            <li>Enterprise use cases where AI and ML have to align with real business constraints</li>
            <li>LLM system design, evaluation, retrieval, and adoption patterns in production settings</li>
            <li>Delivery trade-offs across architecture, deployment, monitoring, and stakeholder communication</li>
          </ul>
        </section>

        <section>
          <h2>How I want the writing to read</h2>
          <ul>
            <li>The business problem and the engineering constraint should be clear from the start</li>
            <li>The decision criteria should matter as much as the technical implementation</li>
            <li>The archive should read like field notes from real enterprise AI work</li>
          </ul>
        </section>
      </div>

      <section class="timeline-card">
        <h2>Current profile</h2>
        <p>A concise summary of the context behind the writing on this site.</p>
        <ul>
          <li>Role: Solution Engineer</li>
          <li>Team: Microsoft AI Build Team</li>
          <li>Location: Korea</li>
          <li>Focus: solving enterprise business problems with AI and ML</li>
        </ul>
      </section>
    </section>

    <SidebarProfile categories={categories} />
  </main>
</BaseLayout>