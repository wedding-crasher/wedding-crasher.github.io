---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogArchive from "../components/BlogArchive.astro";
import { getCategories, getPublishedPosts } from "../utils/blog";

const posts = getPublishedPosts(await getCollection("blog"));
const categories = getCategories(posts);
---

<BaseLayout
  title="Hangwoo Cho | Engineering Notes"
  description="Notes on AI / ML engineering and the lessons I learn along the way."
>
  <BlogArchive
    posts={posts}
    categories={categories}
    eyebrow="Engineering Notes"
    pageTitle="Lessons learned from AI / ML engineering"
    pageDescription="I use this archive to share lessons learned while working on AI / ML engineering."
  />
</BaseLayout>