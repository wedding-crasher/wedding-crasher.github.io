---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogArchive from "../components/BlogArchive.astro";
import { getCategories, getPublishedPosts } from "../utils/blog";

const posts = getPublishedPosts(await getCollection("blog"));
const categories = getCategories(posts);
---

<BaseLayout
  title="Hangwoo Cho | Engineering Notes"
  description="An engineering blog about production ML, LLM, and MLOps work, covering bottlenecks, trade-offs, failures, and decisions."
>
  <BlogArchive
    posts={posts}
    categories={categories}
    eyebrow="Engineering Notes"
    pageTitle="An engineering blog about production problems and decisions"
    pageDescription="I write about the bottlenecks, failures, design changes, and operating decisions that show up in real ML, LLM, and MLOps work. The homepage now serves directly as the full archive."
  />
</BaseLayout>