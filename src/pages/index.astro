---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogArchive from "../components/BlogArchive.astro";
import { getCategories, getPublishedPosts } from "../utils/blog";

const posts = getPublishedPosts(await getCollection("blog"));
const categories = getCategories(posts);
---

<BaseLayout
  title="Hangwoo Cho | Engineering Notes"
  description="A blog by a Solution Engineer on Microsoft's AI Build Team in Korea, focused on solving enterprise business problems with AI and ML."
>
  <BlogArchive
    posts={posts}
    categories={categories}
    eyebrow="Engineering Notes"
    pageTitle="Enterprise AI and ML notes from a Solution Engineer"
    pageDescription="I work on Microsoft's AI Build Team in Korea, helping organizations solve enterprise business problems with AI and ML. This archive collects the technical, product, and delivery lessons behind that work."
  />
</BaseLayout>