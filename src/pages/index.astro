---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogArchive from "../components/BlogArchive.astro";
import { getCategories, getPublishedPosts } from "../utils/blog";

const posts = getPublishedPosts(await getCollection("blog"));
const categories = getCategories(posts);
---

<BaseLayout
  title="Hangwoo Cho | Engineering Notes"
  description="회사에서 진행한 ML과 LLM 프로젝트의 문제 상황, 트레이드오프, 해결 과정을 기록하는 개발 블로그"
>
  <BlogArchive
    posts={posts}
    categories={categories}
    eyebrow="Engineering Notes"
    pageTitle="회사에서 맞닥뜨린 문제를 정리하는 개발 블로그"
    pageDescription="ML, LLM, MLOps 프로젝트에서 실제로 부딪힌 병목, 실패, 설계 변경, 운영 판단을 글로 남깁니다. 홈도 이제 별도 랜딩 없이 전체 아카이브를 바로 보여줍니다."
  />
</BaseLayout>