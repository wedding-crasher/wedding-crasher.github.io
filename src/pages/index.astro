---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeLanding from "../components/HomeLanding.astro";
import { getCategories, getFeaturedPost, getPublishedPosts } from "../utils/blog";

const posts = getPublishedPosts(await getCollection("blog"));
const categories = getCategories(posts);
const featuredPost = getFeaturedPost(posts);
---

<BaseLayout
  title="Hangwoo Cho | Blog-first engineering portfolio"
  description="회사에서 진행한 ML과 LLM 프로젝트의 문제 상황, 트레이드오프, 해결 과정을 기록하는 개발 블로그"
>
  <HomeLanding posts={posts} categories={categories} featuredPost={featuredPost} />
</BaseLayout>