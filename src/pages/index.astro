---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogArchive from "../components/BlogArchive.astro";
import { getCategories, getPublishedPosts } from "../utils/blog";

const posts = getPublishedPosts(await getCollection("blog"));
const categories = getCategories(posts);
---

<BaseLayout
  title="Hangwoo Cho | Engineering Notes"
  description="Engineering Notes on building AI and ML with enterprises in Korea, and documenting the lessons learned along the way."
>
  <BlogArchive
    posts={posts}
    categories={categories}
    eyebrow="Engineering Notes"
    pageTitle="Building AI and ML with enterprises in Korea"
    pageDescription="I work with enterprises in Korea on AI and ML projects, and use this archive to write down what I learn along the way."
  />
</BaseLayout>