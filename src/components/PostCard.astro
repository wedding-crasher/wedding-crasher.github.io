---
import type { BlogEntry } from "../utils/blog";
import { formatDate, slugifyCategory } from "../utils/blog";

interface Props {
  post: BlogEntry;
  variant?: "grid" | "archive";
}

const { post, variant = "grid" } = Astro.props;
const categorySlug = slugifyCategory(post.data.category);
---

<article class:list={["post-card", variant === "archive" ? "post-card--archive" : "post-card--grid"]}>
  <div class="post-card__meta-row">
    <a class="post-card__category" href={`/blog/category/${categorySlug}/`}>
      {post.data.category}
    </a>
    <time datetime={post.data.publishDate.toISOString()}>{formatDate(post.data.publishDate)}</time>
  </div>

  <h2>
    <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
  </h2>

  <p>{post.data.description}</p>

  <div class="post-card__footer">
    <div class="tag-list">
      {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
    <span class="post-card__cta">{variant === "archive" ? "Open note" : "Read note"}</span>
  </div>
</article>